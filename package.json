{
  "name": "uno",
  "version": "1.0.0",
  "scripts": {
    "build": "tsc -p tsconfig.server.json && tsc -p tsconfig.client.json && cp public/index.html dist/ && cp public/style.css dist/",
    "start": "node dist/server.js",
    "dev": "NODE_ENV=development tsx watch src/server.ts",
    "dev:build": "NODE_ENV=development nodemon --watch src --watch public --ext ts,html,css --exec 'npm run build && node dist/server.js'",
    "start:dev": "NODE_ENV=development nodemon dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [],
  "author": "miruku (lovemilk)",
  "license": "BSD-3-Clause",
  "description": "UNO Game Server",
  "dependencies": {
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ws": "^8.0.0",
    "concurrently": "^9.2.0",
    "nodemon": "^3.1.10",
    "pkg": "^5.8.1",
    "playwright": "^1.60.0",
    "tsx": "^4.22.3",
    "typescript": "^5.4.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "main": "dist/server.js",
  "bin": "dist/server.js",
  "pkg": {
    "scripts": [
      "dist/server.js"
    ],
    "assets": [
      "dist/index.html",
      "dist/client.js",
      "dist/style.css",
      "dist/aiplayer.js"
    ]
  },
  "pefile": {
    "version-info": {
      "RT_VERSION": {
        "#1": {
          "0000": {
            "fixed": {
              "file_version": "1.0.0.0",
              "product_version": "1.0.0.0"
            },
            "info": {
              "0409": {
                "CompanyName": "miruku (lovemilk)",
                "ProductName": "UNO Server",
                "FileDescription": "UNO Game Server",
                "LegalCopyright": "Copyright (C) 2026 miruku (lovemilk)",
                "OriginalFilename": "uno-server.exe",
                "InternalName": "uno-server"
              }
            }
          }
        }
      }
    }
  }
}
