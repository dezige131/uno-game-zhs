#!/usr/bin/bash
# 貌似 Gemini 对我的 PE 文件进行了一些神奇操作, IDK what magic things happened

set -euo pipefail

EXE_PATH="$1"

if [ -z "$EXE_PATH" ]; then
  echo "Error: Please specify target exe file."
  exit 1
fi

# 1. 从 package.json 提取各个干净字段
mapfile -t args < <(jq -r '
  (if (.version | split(".") | length) == 3 then .version + ".0" else .version end) as $ver |
  .pefile["version-info"] |
  $ver, .CompanyName, .ProductName, .FileDescription, .OriginalFilename, .InternalName
' package.json)

COPYRIGHT=$(jq -r '.pefile["version-info"].LegalCopyright' package.json)

VER="${args[0]}"
COMPANY="${args[1]}"
REAL_PRODUCT="${args[2]}"
DESC="${args[3]}"
ORIG="${args[4]}"
INTERNAL="${args[5]}"

# 用超长文本让工具开辟出 388 字节的豪华温床
FAKE_PRODUCT="${REAL_PRODUCT}____________________________________________________________________________________________________"

echo "Step 1: Forcing resedit-cli to stretch PE allocation space..."
pnpm resedit \
  --in "$EXE_PATH" \
  --out "$EXE_PATH" \
  --file-version "$VER" \
  --product-version "$VER" \
  --company-name "$COMPANY" \
  --product-name "$FAKE_PRODUCT" \
  --file-description "$DESC" \
  --original-filename "$ORIG" \
  --internal-name "$INTERNAL"

echo "Step 2: Executing ultimate twin-node discrete alignment..."
python3 - << EOF "$EXE_PATH" "$REAL_PRODUCT" "$COPYRIGHT" "$FAKE_PRODUCT"
import sys
import struct

exe_path = sys.argv[1]
real_product = sys.argv[2]
copyright_text = sys.argv[3]
fake_product = sys.argv[4]

with open(exe_path, 'rb') as f:
    data = bytearray(f.read())

target_bytes = fake_product.encode('utf-16le')
key_bytes = "ProductName\x00".encode('utf-16le')

offset = data.find(target_bytes)
if offset == -1:
    print("[CRITICAL] Target mapping block track lost.")
    sys.exit(1)

node_offset = -1
for i in range(offset, max(0, offset - 200), -1):
    if data[i:i+len(key_bytes)] == key_bytes:
        node_offset = i - 6
        break

if node_offset == -1:
    print("[CRITICAL] Node architecture unlocatable.")
    sys.exit(1)

# 稳稳拿到这 388 字节的物理总空间
original_node_len = struct.unpack('<H', data[node_offset:node_offset+2])[0]
print(f"[OK] Located target zone, full length: {original_node_len} bytes.")

def make_string_node(key, val):
    k_buf = (key + "\x00").encode('utf-16le')
    v_buf = (val + "\x00").encode('utf-16le')
    head_len = 6 + len(k_buf)
    padding = (4 - (head_len % 4)) % 4
    total_len = head_len + padding + len(v_buf)
    
    node = bytearray(total_len)
    struct.pack_into('<H', node, 0, total_len)
    struct.pack_into('<H', node, 2, len(v_buf) // 2)
    struct.pack_into('<H', node, 4, 1)
    node[6:6+len(k_buf)] = k_buf
    node[head_len+padding:head_len+padding+len(v_buf)] = v_buf
    return node

# 【神级复位】：在这里，我们分别计算两个独立节点的真实紧凑长度
node_prod = make_string_node("ProductName", real_product)
node_copy = make_string_node("LegalCopyright", copyright_text)

# 计算两个节点独立对齐到 4 字节所需的实际物理空间
prod_len = len(node_prod)
prod_padding = (4 - (prod_len % 4)) % 4
prod_total_required = prod_len + prod_padding

# 关键：由于我们要把总长度锁定在 388 字节（original_node_len），
# 那抛去 ProductName 占用的空间，剩下的所有全部合理合规地划归给 LegalCopyright 节点！
copy_total_allocated = original_node_len - prod_total_required

# 重新修正 LegalCopyright 节点头部宣称的 wLength，让它把剩下的坑位全部名正言顺地吃下
struct.pack_into('<H', node_copy, 0, copy_total_allocated)

# 在缓冲区里把它们两兄弟紧紧挨着平铺好
new_block = bytearray(original_node_len)
new_block[0:prod_len] = node_prod
# 紧随其后放置版权节点，不多占哪怕一个比特的额外空间
new_block[prod_total_required:prod_total_required+len(node_copy)] = node_copy

# 原位全字节无损物理覆盖
data[node_offset:node_offset+original_node_len] = new_block

with open(exe_path, 'wb') as f:
    f.write(data)
print("[SUCCESS] Disjoint twin-node alignment fully synced. Total 388 bytes balanced.")
EOF

echo "All elements fully finalized and cross-locked."